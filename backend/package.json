{
  "name": "@codepulse/backend",
  "version": "1.0.0",
  "description": "CodePulse Backend - API para execução de código segura",
  "license": "MIT",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "echo 'No build needed'",
    "start": "node src/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js",
    "format": "prettier --write src",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "fastify": "^4.24.0",
    "axios": "^1.6.0",
    "zod": "^3.22.0",
    "@fastify/rate-limit": "^8.0.0",
    "@fastify/cors": "^8.4.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "vitest": "^0.34.0",
    "@vitest/coverage-v8": "^0.34.0",
    "prettier": "^3.0.0"
  }
}
